__pycache__/
*.pyc

# Regenerable historical-archive derived data: the normalized per-station
# hourly JSONL is ~10x more verbose per row than logs/raw_cache/'s compact
# format (repeats station metadata on every row) and fully regenerates in
# seconds via `python3 historical_data.py sync` - see docs/DATA_ARCHITECTURE.md.
# Only the small manifests (tens of KB) are committed.
logs/historical/station_hourly/*.jsonl
logs/historical/station_10min/*.jsonl
logs/historical/ground_truth/*.jsonl
logs/historical/datasets/*.jsonl

# Transient operational nowcast snapshot (station_nowcast.py) - rewritten
# every forecast run from a bounded recent-tail fetch, never meant to be a
# historical record itself. The forecast issuance record
# (logs/forecast_issuances.jsonl) is what preserves "what was known at
# issuance time" for future retraining - see docs/DATA_ARCHITECTURE.md.
logs/current_station_observations.json

# Failure-diagnostic screenshots/HTML from kitesailing_weather.py's
# attempt_reading() - uploaded as a short-lived GitHub Actions artifact by
# .github/workflows/kitesailing-sampler.yml, never committed to the repo.
logs/kitesailing_failure_artifacts/
